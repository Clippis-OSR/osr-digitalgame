{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "p44.schemas.treasure_compiled.v1",
  "title": "Treasure Tables (Compiled)",
  "type": "object",
  "required": [
    "schema_version",
    "content_hash",
    "generated_from",
    "tables_by_id",
    "value_tables_by_id",
    "magic_lists_by_id",
    "unresolved"
  ],
  "properties": {
    "schema_version": {"const": "treasure_compiled.v1"},
    "content_hash": {"type": "string"},
    "generated_from": {"type": "string"},
    "tables_by_id": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/treasure_table_compiled"}
    },
    "value_tables_by_id": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/value_table_compiled"}
    },
    "magic_lists_by_id": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/magic_list_compiled"}
    },
    "unresolved": {
      "type": "array",
      "items": {"$ref": "#/$defs/unresolved_ref"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "dice_obj": {
      "type": "object",
      "required": ["count", "sides"],
      "properties": {
        "count": {"type": "integer", "minimum": 1},
        "sides": {"type": "integer", "minimum": 2}
      },
      "additionalProperties": false
    },
    "expr_obj": {
      "type": "object",
      "required": ["expr"],
      "properties": {"expr": {"type": "string"}},
      "additionalProperties": false
    },
    "treasure_table_compiled": {
      "type": "object",
      "required": ["table_id", "kind", "dice", "entries", "validation"],
      "properties": {
        "table_id": {"type": "string"},
        "kind": {"enum": ["hoard", "individual"]},
        "dice": {"$ref": "#/$defs/dice_obj"},
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/treasure_entry_compiled"}
        },
        "validation": {
          "type": "object",
          "required": ["coverage_ok", "overlap_ok"],
          "properties": {
            "coverage_ok": {"type": "boolean"},
            "overlap_ok": {"type": "boolean"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "treasure_entry_compiled": {
      "type": "object",
      "required": ["lo", "hi", "drops"],
      "properties": {
        "lo": {"type": "integer"},
        "hi": {"type": "integer"},
        "drops": {
          "type": "array",
          "items": {"$ref": "#/$defs/drop_compiled"}
        }
      },
      "additionalProperties": false
    },
    "drop_compiled": {
      "oneOf": [
        {"$ref": "#/$defs/drop_coins_compiled"},
        {"$ref": "#/$defs/drop_gems_compiled"},
        {"$ref": "#/$defs/drop_jewelry_compiled"},
        {"$ref": "#/$defs/drop_magic_compiled"}
      ]
    },
    "drop_coins_compiled": {
      "type": "object",
      "required": ["type", "rolls"],
      "properties": {
        "type": {"const": "coins"},
        "rolls": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/expr_obj"}
        }
      },
      "additionalProperties": false
    },
    "drop_gems_compiled": {
      "type": "object",
      "required": ["type", "count", "value_table_id"],
      "properties": {
        "type": {"const": "gems"},
        "count": {"$ref": "#/$defs/expr_obj"},
        "value_table_id": {"type": "string"}
      },
      "additionalProperties": false
    },
    "drop_jewelry_compiled": {
      "type": "object",
      "required": ["type", "count", "value_table_id"],
      "properties": {
        "type": {"const": "jewelry"},
        "count": {"$ref": "#/$defs/expr_obj"},
        "value_table_id": {"type": "string"}
      },
      "additionalProperties": false
    },
    "drop_magic_compiled": {
      "type": "object",
      "required": ["type", "picks", "magic_list_id"],
      "properties": {
        "type": {"const": "magic"},
        "picks": {"$ref": "#/$defs/expr_obj"},
        "magic_list_id": {"type": "string"},
        "resolved": {
          "type": "object",
          "properties": {
            "mode": {"type": "string"},
            "all_item_ids_resolved": {"type": "boolean"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "value_table_compiled": {
      "type": "object",
      "required": ["dice", "bands"],
      "properties": {
        "dice": {"$ref": "#/$defs/dice_obj"},
        "bands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["lo", "hi", "gp_value"],
            "properties": {
              "lo": {"type": "integer"},
              "hi": {"type": "integer"},
              "gp_value": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "magic_list_compiled": {
      "type": "object",
      "required": ["dice", "entries"],
      "properties": {
        "dice": {"$ref": "#/$defs/dice_obj"},
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["lo", "hi", "item_id", "resolved"],
            "properties": {
              "lo": {"type": "integer"},
              "hi": {"type": "integer"},
              "item_id": {"type": "string"},
              "resolved": {"type": "boolean"}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "unresolved_ref": {
      "type": "object",
      "required": ["kind", "ref", "where"],
      "properties": {
        "kind": {"type": "string"},
        "ref": {"type": "string"},
        "where": {"type": "string"}
      },
      "additionalProperties": true
    }
  }
}
